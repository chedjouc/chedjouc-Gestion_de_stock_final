<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - Gestion Stock</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: radial-gradient(circle at top, rgba(13,110,253,0.18), transparent 28%),
                        linear-gradient(135deg, #eff2ff 0%, #f8fbff 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .form-signin {
            width: 100%;
            max-width: 380px;
            padding: 32px;
            background: #ffffff;
            border-radius: 22px;
            box-shadow: 0 24px 60px rgba(13,110,253,0.12);
            border: 1px solid rgba(13,110,253,0.12);
        }
        .form-signin h1 {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 1.6rem;
            color: #0d6efd;
        }
        .form-signin .form-control {
            border-radius: 12px;
            padding: 18px 16px;
        }
        .form-signin .btn-primary {
            border-radius: 12px;
            padding: 12px 20px;
            font-weight: 600;
            box-shadow: 0 12px 24px rgba(13,110,253,0.18);
        }
        .form-signin .form-floating > .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.15rem rgba(13,110,253,0.15);
        }
        .form-signin .text-muted {
            color: #6c757d !important;
        }
    </style>
</head>
<body class="text-center">
    
    <main class="form-signin">
        <form action="/login" method="POST">
            <h1 class="h3 mb-3 fw-normal">Se connecter</h1>

            <% if (typeof error !== 'undefined') { %>
                <div class="alert alert-danger" role="alert">
                    <%= error %>
                </div>
            <% } %>

            <div class="form-floating mb-3">
                <input type="email" name="email" class="form-control" id="floatingInput" placeholder="name@example.com" required>
                <label for="floatingInput">Adresse Email</label>
            </div>
            <div class="form-floating mb-3">
                <input type="password" name="motDePasse" class="form-control" id="floatingPassword" placeholder="Password" required>
                <label for="floatingPassword">Mot de passe</label>
            </div>

            <button class="w-100 btn btn-lg btn-primary" type="submit">Connexion</button>
            <p class="mt-5 mb-3 text-muted">© <%= new Date().getFullYear() %></p>
        </form>
    </main>
    
</body>
</html>