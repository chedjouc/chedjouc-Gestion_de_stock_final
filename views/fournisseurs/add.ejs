<%- include('../partials/header') %>

<div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <h2 class="form-title"><i class="fas fa-plus me-2"></i>Ajouter un fournisseur</h2>
        <p class="form-subtitle">Ajoutez un partenaire de livraison et ses coordonnées.</p>
    </div>
</div>

<div class="row">
    <div class="col-xl-6 col-lg-7">
        <div class="card form-card">
            <div class="card-body">
                <% if (errors && errors.length > 0) { %>
                    <div class="alert alert-danger">
                        <% errors.forEach(error => { %>
                            <div><%= error.msg %></div>
                        <% }); %>
                    </div>
                <% } %>

                <form method="POST" action="/fournisseurs">
                    <div class="mb-3">
                        <label for="nom" class="form-label">Nom du fournisseur *</label>
                        <input type="text" class="form-control" id="nom" name="nom" value="<%= formData ? formData.nom : '' %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="contactEmail" class="form-label">Email de contact *</label>
                        <input type="email" class="form-control" id="contactEmail" name="contactEmail" value="<%= formData ? formData.contactEmail : '' %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="telephone" class="form-label">Téléphone</label>
                        <input type="tel" class="form-control" id="telephone" name="telephone" value="<%= formData ? formData.telephone : '' %>">
                    </div>

                    <div class="mb-3">
                        <label for="adresse" class="form-label">Adresse</label>
                        <textarea class="form-control" id="adresse" name="adresse" rows="3"><%= formData ? formData.adresse : '' %></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Ajouter
                        </button>
                        <a href="/fournisseurs" class="btn btn-secondary">
                            <i class="fas fa-times me-2"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
