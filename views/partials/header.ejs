<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Gestion Stock' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #eff2ff 0%, #f8fbff 100%);
            min-height: 100vh;
            color: #343a40;
        }
        .navbar {
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
        .navbar-brand {
            color: #0d6efd !important;
            font-size: 1.25rem;
        }
        .sidebar {
            background: #0d6efd;
            min-height: calc(100vh - 56px);
            padding: 24px 0;
        }
        .sidebar a {
            color: rgba(255,255,255,0.9);
            text-decoration: none;
            padding: 14px 24px;
            display: block;
            transition: all 0.2s ease-in-out;
            font-weight: 500;
        }
        .sidebar a:hover,
        .sidebar a.active {
            background: rgba(255,255,255,0.12);
            color: #ffffff;
            border-left: 4px solid rgba(255,255,255,0.85);
        }
        .sidebar p {
            color: rgba(255,255,255,0.75);
        }
        .main-content {
            padding: 24px;
        }
        .card {
            border: none;
            box-shadow: 0 18px 50px rgba(13,110,253,0.08);
            border-radius: 18px;
            margin-bottom: 24px;
        }
        .card-header {
            background: transparent;
            border-bottom: none;
        }
        .table thead {
            background: #0d6efd;
            color: #fff;
        }
        .table thead th {
            border-top: 0;
        }
        .table tbody tr:hover {
            background: rgba(13,110,253,0.04);
        }
        .btn-primary {
            background: linear-gradient(135deg, #0d6efd 0%, #5c7cfa 100%);
            border: none;
            box-shadow: 0 12px 24px rgba(13,110,253,0.18);
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, #0b5ed7 0%, #4f6ef5 100%);
        }
        .page-title {
            font-size: 1.85rem;
            letter-spacing: -0.02em;
            margin-bottom: 1.25rem;
        }
        .dashboard-card {
            min-height: 160px;
        }
        .dashboard-card .card-body {
            padding: 1.8rem;
        }
        .dashboard-card h5 {
            color: #0d6efd;
            font-weight: 600;
        }
        .sidebar hr {
            border-color: rgba(255,255,255,0.15);
            margin: 1rem 0;
        }
        .footer {
            background: transparent;
            border-top: 1px solid rgba(0,0,0,0.05);
            margin-top: 32px;
        }
        .badge-low-stock {
            background: #ffe8cc;
            color: #9a6200;
        }
        .badge-available {
            background: #d1e7dd;
            color: #0f5132;
        }
        .bg-soft {
            background: rgba(13,110,253,0.08);
        }
        .card h3 {
            font-size: 2.15rem;
            margin-bottom: 0.5rem;
        }
        .form-card {
            border-radius: 24px;
            border: 1px solid rgba(13,110,253,0.08);
            box-shadow: 0 24px 60px rgba(13,110,253,0.08);
        }
        .form-card .card-body {
            padding: 2rem;
        }
        .form-title {
            font-size: 1.75rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            margin-bottom: 0.35rem;
        }
        .form-subtitle {
            color: #6c757d;
            margin-bottom: 1.5rem;
        }
        .form-note {
            color: #6c757d;
            font-size: 0.95rem;
        }
        .form-control,
        .form-select {
            border-radius: 12px;
        }
        .btn-secondary {
            background: #f8f9fa;
            color: #343a40;
            border: 1px solid rgba(0,0,0,0.08);
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-boxes me-2"></i>GestionStock
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user me-2"></i><%= user ? user.prenom + ' ' + user.nom : 'Utilisateur' %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li><a class="dropdown-item" href="/logout"><i class="fas fa-sign-out-alt me-2"></i>Déconnexion</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-3 col-lg-2 sidebar">
                <a href="/" class="<%= typeof currentPage !== 'undefined' && currentPage === 'dashboard' ? 'active' : '' %>">
                    <i class="fas fa-chart-line me-2"></i>Tableau de bord
                </a>
                <hr>
                <p class="px-3 small fw-bold text-muted">GESTION</p>
                <a href="/produits" class="<%= typeof currentPage !== 'undefined' && currentPage === 'produits' ? 'active' : '' %>">
                    <i class="fas fa-boxes me-2"></i>Produits
                </a>
                <a href="/utilisateurs" class="<%= typeof currentPage !== 'undefined' && currentPage === 'utilisateurs' ? 'active' : '' %>">
                    <i class="fas fa-users me-2"></i>Utilisateurs
                </a>
                <a href="/categories" class="<%= typeof currentPage !== 'undefined' && currentPage === 'categories' ? 'active' : '' %>">
                    <i class="fas fa-tag me-2"></i>Catégories
                </a>
                <a href="/fournisseurs" class="<%= typeof currentPage !== 'undefined' && currentPage === 'fournisseurs' ? 'active' : '' %>">
                    <i class="fas fa-truck me-2"></i>Fournisseurs
                </a>
                <a href="/api/stock/historique" class="<%= typeof currentPage !== 'undefined' && currentPage === 'historique' ? 'active' : '' %>">
                    <i class="fas fa-history me-2"></i>Historique
                </a>
            </div>

            <!-- Main Content -->
            <div class="col-md-9 col-lg-10 main-content">
