<%- include('../partials/header') %>

<div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <h2 class="page-title mb-2"><i class="fas fa-boxes me-2"></i>Produits</h2>
        <p class="text-muted mb-0">Gestion des stocks avec alerte visuelle et suivi rapide.</p>
    </div>
    <div class="d-flex flex-column flex-sm-row gap-3 w-100 w-md-auto">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0"><i class="fas fa-search"></i></span>
            <input id="searchProduit" type="search" class="form-control border-start-0" placeholder="Rechercher un produit..." onkeyup="filterTable('searchProduit', 'produitTable')">
        </div>
        <a href="/produits/add" class="btn btn-primary btn-lg">
            <i class="fas fa-plus me-2"></i>Ajouter
        </a>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table id="produitTable" class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>SKU</th>
                    <th>Nom</th>
                    <th>Catégorie</th>
                    <th>Fournisseur</th>
                    <th>Prix</th>
                    <th>Quantité</th>
                    <th>Min.</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (produits && produits.length > 0) { %>
                    <% produits.forEach(produit => { %>
                        <tr class="<%= produit.quantite < produit.quantiteMin ? 'table-warning' : '' %>">
                            <td><code><%= produit.sku %></code></td>
                            <td><strong><%= produit.nom %></strong></td>
                            <td><i class="fas fa-tag text-secondary me-1"></i><%= produit.Categorie ? produit.Categorie.nom : '-' %></td>
                            <td><i class="fas fa-truck text-secondary me-1"></i><%= produit.Fournisseur ? produit.Fournisseur.nom : '-' %></td>
                            <td><span class="text-primary fw-semibold"><%= parseFloat(produit.prix).toFixed(2) %> $</span></td>
                            <td>
                                <span class="badge <%= produit.quantite < produit.quantiteMin ? 'bg-danger' : 'bg-success' %>">
                                    <%= produit.quantite %>
                                </span>
                            </td>
                            <td><span class="text-muted"><%= produit.quantiteMin %></span></td>
                            <td>
                                <a href="/produits/<%= produit.id %>/edit" class="btn btn-sm btn-warning" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-danger" onclick="deleteProduit(<%= produit.id %>)" title="Supprimer">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">Aucun produit</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
function filterTable(inputId, tableId) {
    const query = document.getElementById(inputId).value.toLowerCase();
    const rows = document.querySelectorAll(`#${tableId} tbody tr`);
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(query) ? '' : 'none';
    });
}

function deleteProduit(id) {
    if (confirm('Êtes-vous sûr de vouloir supprimer ce produit ?')) {
        fetch(`/produits/${id}`, {
            method: 'DELETE'
        }).then(() => location.reload());
    }
}
</script>

<%- include('../partials/footer') %>