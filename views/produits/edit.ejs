<%- include('../partials/header') %>

<div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <h2 class="form-title"><i class="fas fa-edit me-2"></i>Modifier un produit</h2>
        <p class="form-subtitle">Mettez à jour les informations et le niveau de stock du produit.</p>
    </div>
</div>

<div class="row">
    <div class="col-xl-8 col-lg-9">
        <div class="card form-card">
            <div class="card-body">
                <% if (errors && errors.length > 0) { %>
                    <div class="alert alert-danger">
                        <% errors.forEach(error => { %>
                            <div><%= error.msg %></div>
                        <% }); %>
                    </div>
                <% } %>

                <form method="POST" action="/produits/<%= produit.id %>">
                    <div class="mb-3">
                        <label for="nom" class="form-label">Nom du produit *</label>
                        <input type="text" class="form-control" id="nom" name="nom" value="<%= produit.nom %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea class="form-control" id="description" name="description" rows="3"><%= produit.description || '' %></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="sku" class="form-label">SKU</label>
                        <input type="text" class="form-control" value="<%= produit.sku %>" disabled>
                        <small class="text-muted">Le SKU ne peut pas être modifié</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="categorieId" class="form-label">Catégorie *</label>
                            <select class="form-select" id="categorieId" name="categorieId" required>
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat.id %>" <%= produit.categorieId == cat.id ? 'selected' : '' %>>
                                        <%= cat.nom %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="fournisseurId" class="form-label">Fournisseur *</label>
                            <select class="form-select" id="fournisseurId" name="fournisseurId" required>
                                <% fournisseurs.forEach(fou => { %>
                                    <option value="<%= fou.id %>" <%= produit.fournisseurId == fou.id ? 'selected' : '' %>>
                                        <%= fou.nom %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="prix" class="form-label">Prix ($) *</label>
                            <input type="number" class="form-control" id="prix" name="prix" step="0.01" min="0" value="<%= parseFloat(produit.prix).toFixed(2) %>" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="quantite" class="form-label">Quantité *</label>
                            <input type="number" class="form-control" id="quantite" name="quantite" min="0" value="<%= produit.quantite %>" required>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="quantiteMin" class="form-label">Quantité minimum</label>
                            <input type="number" class="form-control" id="quantiteMin" name="quantiteMin" min="0" value="<%= produit.quantiteMin %>">
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="actif" class="form-label">
                                <input type="checkbox" id="actif" name="actif" <%= produit.actif ? 'checked' : '' %>>
                                Actif
                            </label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Mettre à jour
                        </button>
                        <a href="/produits" class="btn btn-secondary">
                            <i class="fas fa-times me-2"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>