<%- include('../partials/header') %>

<div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <h2 class="form-title"><i class="fas fa-edit me-2"></i>Modifier un utilisateur</h2>
        <p class="form-subtitle">Mettez à jour les informations de compte et les rôles.</p>
    </div>
</div>

<div class="row">
    <div class="col-xl-6 col-lg-7">
        <div class="card form-card">
            <div class="card-body">
                <% if (errors && errors.length > 0) { %>
                    <div class="alert alert-danger">
                        <% errors.forEach(error => { %>
                            <div><%= error.msg %></div>
                        <% }); %>
                    </div>
                <% } %>

                <form method="POST" action="/utilisateurs/<%= utilisateur.id %>">
                    <div class="mb-3">
                        <label for="nom" class="form-label">Nom *</label>
                        <input type="text" class="form-control" id="nom" name="nom" value="<%= utilisateur.nom %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="prenom" class="form-label">Prénom *</label>
                        <input type="text" class="form-control" id="prenom" name="prenom" value="<%= utilisateur.prenom %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email *</label>
                        <input type="email" class="form-control" id="email" name="email" value="<%= utilisateur.email %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="motDePasse" class="form-label">Nouveau mot de passe (laisser vide pour ne pas modifier)</label>
                        <input type="password" class="form-control" id="motDePasse" name="motDePasse">
                        <small class="text-muted">Minimum 6 caractères si changement</small>
                    </div>

                    <div class="mb-3">
                        <label for="roleId" class="form-label">Rôle *</label>
                        <select class="form-select" id="roleId" name="roleId" required>
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>" <%= utilisateur.roleId == role.id ? 'selected' : '' %>>
                                    <%= role.nom %>
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="actif" class="form-label">
                            <input type="checkbox" id="actif" name="actif" <%= utilisateur.actif ? 'checked' : '' %>>
                            Compte actif
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Mettre à jour
                        </button>
                        <a href="/utilisateurs" class="btn btn-secondary">
                            <i class="fas fa-times me-2"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>